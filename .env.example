# 랭퓨즈(Langfuse) 연결 설정 예시 — 실제 값은 .env 에 채운다 (.env는 git 미추적)
# 키 발급: 랭퓨즈 서버 로그인 → 프로젝트 생성 → Settings → API Keys

# 랭퓨즈 서버 주소 (로컬 자가호스팅 서버)
LANGFUSE_BASE_URL=http://192.168.15.73:3000

# 프로젝트별 API 키 쌍
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# 서비스 API 키 (Vercel 환경변수와 동일)
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
